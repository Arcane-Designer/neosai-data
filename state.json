    {
      "japanese": "いつ",
      "reading_romaji": "itsu",
      "translation": "when",
      "casual_usage": "Dropped straight into casual questions — 「いつくるの？」(Itsu kuru no?) means 'When are you coming?' It pairs naturally with verbs like いく and くる that you already know.",
      "formal_usage": "いつ itself never changes form; only the verb after it shifts — 「いつきますか？」(Itsu kimasu ka?) is the polite equivalent.",
      "similar_words": [
        { "japanese": "どこ", "romaji": "doko", "translation": "where" },
        { "japanese": "だれ", "romaji": "dare", "translation": "who" },
        { "japanese": "なに", "romaji": "nani", "translation": "what" }
      ],
